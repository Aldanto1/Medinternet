# Скопируйте как .env и заполните.

# Neon: строка подключения ОТДЕЛЬНОЙ read-only роли crm_reader (см. migrations/002_crm_role.sql)
CRM_DB_URL=postgresql://crm_reader:ПАРОЛЬ@ep-xxx-pooler.neon.tech/neondb?sslmode=require

# Токен ОСНОВНОГО бота (тот же, что у бота) — им шлём сообщения пользователям
MAIN_BOT_TOKEN=

# JWT
JWT_SECRET=смените_на_длинную_случайную_строку
JWT_TTL_HOURS=12

# Учётные данные специалиста CRM (MVP)
CRM_LOGIN_EMAIL=admin@medinternet.ru
CRM_LOGIN_PASSWORD=

# Redis для очереди arq
REDIS_URL=redis://localhost:6379

# Троттлинг рассылки (сообщений/сек)
SEND_RATE_PER_SEC=25

# Порт API (Railway задаёт PORT сам)
API_PORT=8090
