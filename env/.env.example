# Скопируйте этот файл как .env и заполните значения
# cp .env.example .env

# Telegram Bot Token (получен от @BotFather)
BOT_TOKEN=

# База данных Neon / PostgreSQL (Connection String из дашборда Neon)
DATABASE_URL=

# Публичный HTTPS-адрес mini app (например, ссылка от cloudflared-туннеля).
# Меняется при каждом перезапуске быстрого туннеля — обновляйте здесь.
WEBAPP_URL=

# Порт локального веб-сервера mini app (по умолчанию 8080)
WEBAPP_PORT=8080

# API сервера Medinternet
API_SERVER_URL=
API_SERVER_KEY=

# Нейросеть в mini app (сейчас OpenRouter, временно вместо RXCode AI)
# Для OpenRouter URL вставлять целиком, вместе с /api/v1:
NEURO_API_URL=https://openrouter.ai/api/v1
NEURO_API_KEY=
# Модель OpenRouter (по умолчанию openai/gpt-4o-mini)
NEURO_MODEL=openai/gpt-4o-mini
